# Normalize line endings across platforms.
# Shell scripts MUST be LF (broken otherwise on Linux/WSL/Git Bash).
# .bat files MUST be CRLF (cmd.exe parser is picky).
* text=auto eol=lf

*.sh   text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.toml text eol=lf

# cmd.exe parses .bat/.cmd by byte offset assuming CRLF — an LF-only file
# misparses and leaks a fragment (e.g. the `M` of `REM`) as a bogus command
# ('M' is not recognized…). `text eol=crlf` proved unreliable on checkout here
# (core.autocrlf=true + LF blob → git skips the LF→CRLF conversion), so pin
# these as binary-verbatim: the CRLF bytes committed are what gets checked out.
*.bat  -text
*.cmd  -text
*.ps1  -text

# Binary
*.png  binary
*.jpg  binary
*.ico  binary
