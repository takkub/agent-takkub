__pycache__/
*.pyc
*.pyo
.venv/
venv/
# Spawn-safe launcher copied from .venv by agent-takkub.bat (issue #94) —
# machine-specific (embeds the venv python path); regenerated every launch.
bin/takkub.exe
*.egg-info/
build/
dist/
src/agent_takkub/_assets/
.idea/
.vscode/
projects.json
runtime/
*.log
# Local issue-store fallback (written only when gh is unavailable). With
# issues now defaulting to the agent-takkub repo, this can land at repo root.
.takkub_issues.json

# Claude Code per-user local settings (permission allows, MCP overrides
# vary per developer machine).
.claude/settings.local.json

# Gemini CLI per-machine config (MCP servers etc.) — tool-managed, not
# cockpit source.
.gemini/

# Chrome port files and per-shard user-data-dir created by qa shard panes.
.takkub/

# Playwright MCP session artifacts (snapshots/console logs) — transient.
.playwright-mcp/

# Local eval / scratch notes — kept out of the repo on purpose.
docs/eval/

# Cockpit-managed Codex cheatsheet — auto-planted at codex pane
# spawn time, marker-tagged, never user-authored. Safe to ignore.
AGENTS.md
# Cockpit-managed Gemini cheatsheet — same pattern as AGENTS.md above.
GEMINI.md
# Review/audit docs are intentionally committed even if the filename
# happens to be `gemini.md` (case-insensitive match on Windows).
!docs/**/gemini.md
# Gemini-role stand-in prompt (claude substitute) — a real source file,
# not the auto-planted cheatsheet. Negate the case-insensitive GEMINI.md match.
!.claude/agents/gemini.md

# Scheduled-tasks lock — runtime, per-machine (created by /schedule).
.claude/scheduled_tasks.lock

# Local scratch scripts / experiments — not repo source.
scratch/

# Large local media tarballs (gameplay captures etc.) — never committed.
*.tar

# VS Code extension build artifacts (built locally; no source tracked here).
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# Per-pane git worktree isolation (issue #81) — DATA_HOME/worktrees. In a dev
# checkout DATA_HOME == repo root, so isolated worktrees land here; never track them.
worktrees/
